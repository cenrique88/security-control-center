generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  TECHNICIAN
  SALES
  MONITORING
}

enum CustomerStatus {
  ACTIVE
  PROSPECT
  INACTIVE
}

enum WorkOrderStatus {
  SCHEDULED
  IN_PROGRESS
  WAITING_CUSTOMER
  COMPLETED
  CANCELLED
}

enum ServiceType {
  CCTV
  ALARM
  ACCESS_CONTROL
  GPS
  NETWORKING
  MAINTENANCE
  OTHER
}

enum InventoryMovementType {
  IN
  OUT
  ADJUST
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id          String         @id @default(cuid())
  reference   String         @unique
  name        String
  legalName   String?
  taxId       String?
  email       String?
  phone       String?
  address     String?
  logoUrl     String?
  status      CustomerStatus @default(PROSPECT)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workOrders  WorkOrder[]
  sites       Site[]
  quotes      Quote[]
  payments    Payment[]
  documents   CustomerDocument[]
}

model CustomerDocument {
  id         String   @id @default(cuid())
  customerId String
  name       String
  mimeType   String?
  size       Int?
  dataUrl    String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Site {
  id          String             @id @default(cuid())
  customerId  String
  name        String
  address     String
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  customer    Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  equipment   InstalledDevice[]
  workOrders  WorkOrder[]
}

model WorkOrder {
  id          String          @id @default(cuid())
  customerId  String
  siteId      String?
  title       String
  type        ServiceType
  status      WorkOrderStatus @default(SCHEDULED)
  scheduledAt DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  site        Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]
}

model InstalledDevice {
  id          String      @id @default(cuid())
  siteId      String
  type        ServiceType
  brand       String?
  model       String?
  serial      String?
  ipAddress   String?
  installedAt DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  site        Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  inventoryMovements InventoryMovement[]
}

model InventoryItem {
  id               String              @id @default(cuid())
  sku              String?             @unique
  name             String
  category         ServiceType?
  unit             String              @default("u")
  stock            Int                 @default(0)
  minStock         Int                 @default(0)
  managedStock     Boolean             @default(true)
  location         String?
  supplier         String?
  supplierCategory String?
  costPrice        Decimal?            @db.Decimal(12, 2)
  taxAmount        Decimal?            @db.Decimal(12, 2)
  priceWithTax     Decimal?            @db.Decimal(12, 2)
  currency         String?             @default("USD")
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  movements        InventoryMovement[]
}

model InventoryMovement {
  id              String                @id @default(cuid())
  itemId          String
  type            InventoryMovementType
  quantity        Int
  stockAfter      Int
  reason          String?
  workOrderId     String?
  installedDeviceId String?
  createdAt       DateTime              @default(now())
  item            InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  workOrder       WorkOrder?            @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  installedDevice InstalledDevice?      @relation(fields: [installedDeviceId], references: [id], onDelete: SetNull)
}

model Quote {
  id          String   @id @default(cuid())
  customerId  String
  number      String   @unique
  title       String
  laborPoints Int      @default(0)
  subtotal    Decimal  @db.Decimal(12, 2)
  tax         Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(cuid())
  customerId  String
  concept     String
  amount      Decimal  @db.Decimal(12, 2)
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id              String   @id @default(cuid())
  name            String
  plate           String?  @unique
  traccarDeviceId String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
